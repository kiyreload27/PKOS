generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. The Knowledge Graph (Core Domain)
// ------------------------------------------------------

/// The immutable identity anchor for all knowledge within PKOS.
model Entity {
  id      String  @id // UUID generated by domain
  typeId  String // Reference to EntityType registry
  owner   String // The actor who owns this entity
  spaceId String? // Optional workspace grouping

  // Identity Layer (Separating naming/discovery from the raw entity)
  externalIds String[] // Prevents duplication (e.g., GitHub repo IDs)
  aliases     String[] // Alternate search strings

  // Intrinsic Properties
  traits       String[] // e.g. 'Physical Resource', 'Software'
  capabilities String[] // e.g. 'Searchable', 'Runnable'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Graph relations
  resources         Resource[]
  outboundRelations Relationship[] @relation("SourceEntity")
  inboundRelations  Relationship[] @relation("TargetEntity")
  observations      Observation[]
}

/// A structured, typed edge between two entities.
model Relationship {
  id               String  @id // UUID generated by domain
  sourceId         String
  targetId         String
  typeId           String // e.g. 'references', 'contains'
  confidence       Float // Strictly 0-1
  reason           String?
  provenanceSource String // e.g. 'AI', 'User', 'Plugin'
  generatedBy      String?
  evidenceId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source   Entity    @relation("SourceEntity", fields: [sourceId], references: [id], onDelete: Cascade)
  target   Entity    @relation("TargetEntity", fields: [targetId], references: [id], onDelete: Cascade)
  evidence Evidence? @relation(fields: [evidenceId], references: [id], onDelete: SetNull)

  @@index([sourceId])
  @@index([targetId])
}

// ------------------------------------------------------
// 2. Integration & Sourcing
// ------------------------------------------------------

/// The raw, immutable staging area for all incoming data.
model Capture {
  id       String @id
  content  String
  source   String // Where it came from (e.g., 'Universal Capture', 'API')
  status   String // e.g., 'RECEIVING', 'QUEUED', 'ANALYSING', 'COMPLETED', 'FAILED'
  analysis Json? // Stores the CaptureAnalyzer output

  failureReason String?
  retryCount    Int       @default(0)
  lastAttempt   DateTime?

  receivedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resources Resource[]
}

/// External data and state mapped into the PKOS ecosystem.
model Resource {
  id          String  @id // UUID generated by domain
  entityId    String
  type        String
  uri         String  @unique
  status      String
  health      Int // 0-100
  source      String // Defines the Knowledge Provenance Source
  rawMetadata Json    @default("{}")
  captureId   String? // Optional reference to the Capture that created this Resource

  entity    Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)
  capture   Capture?   @relation(fields: [captureId], references: [id], onDelete: SetNull)
  syncState SyncState?

  @@index([entityId])
}

/// Tracks the synchronization lifecycle of an external Resource.
model SyncState {
  resourceId      String    @id
  lastSync        DateTime
  nextSync        DateTime?
  syncStatus      String // 'IDLE', 'SYNCING', 'ERROR', 'DISABLED'
  lastError       String?
  providerVersion String?
  checksum        String?

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

// ------------------------------------------------------
// 3. AI & Observations
// ------------------------------------------------------

/// An AI reasoning conclusion. Evolves through Hypothesis -> Supported -> Verified -> Fact -> Deprecated.
model Observation {
  id              String   @id
  entityId        String
  statement       String
  state           String // 'HYPOTHESIS', 'SUPPORTED', 'VERIFIED', 'FACT', 'DEPRECATED'
  confidenceValue Float
  evidenceLinks   String[]
  evidenceId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entity   Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  evidence Evidence? @relation(fields: [evidenceId], references: [id], onDelete: SetNull)

  @@index([entityId])
}

/// The verifiable source for an Observation or Relationship
model Evidence {
  id              String  @id
  sourceCaptureId String?
  entityId        String
  type            String
  excerpt         String
  uri             String?
  confidence      Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  observations  Observation[]
  relationships Relationship[]
}

/// Vector embeddings for semantic search and graph distance.
model Embedding {
  id       String @id
  targetId String // Can point to Entity, Resource, or Observation
  model    String
  // In a real PG schema we'd use pgvector here, but keeping it generic for Prisma
  vector   Json

  @@index([targetId])
}

/// Versioned summaries generated by the AI
model EntitySummary {
  id        String   @id
  entityId  String
  version   Int
  short     String
  medium    String
  technical String
  createdAt DateTime @default(now())

  @@index([entityId])
}

// ------------------------------------------------------
// 4. Context & Situational Awareness
// ------------------------------------------------------

/// Drives recommendations by explicitly defining what the user is focused on.
model Context {
  id              String   @id
  name            String
  type            String // e.g. 'Work Session'
  isActive        Boolean  @default(false)
  participants    String[]
  activeResources String[]
  relatedEntities String[] // Array of EntityIds

  timeRangeStart DateTime?
  timeRangeEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------
// 5. Event Sourcing & Timeline
// ------------------------------------------------------

/// The immutable source of truth describing what *did* happen.
model PKOSEvent {
  id          String @id // Formally eventId
  type        String
  aggregateId String // Can refer to Entity, Capture, Context, etc.
  version     Int
  payload     Json

  correlationId String?
  causationId   String?
  captureId     String?
  actor         String  @default("System")
  source        String  @default("Core")

  timestamp DateTime @default(now())

  @@unique([aggregateId, version])
}

// ------------------------------------------------------
// 6. Projections (CQRS Read Models)
// ------------------------------------------------------

model DashboardProjection {
  id                String   @id
  projectionVersion Int
  lastEventId       String?
  generatedAt       DateTime @default(now())

  data Json // Denormalized payload for UI consumption
}

model TimelineProjection {
  id                String   @id
  projectionVersion Int
  lastEventId       String?
  generatedAt       DateTime @default(now())

  data Json
}

model CaptureProjection {
  id                String   @id
  projectionVersion Int
  lastEventId       String?
  generatedAt       DateTime @default(now())

  data Json
}

model InboxProjection {
  id                String   @id
  projectionVersion Int
  lastEventId       String?
  generatedAt       DateTime @default(now())

  data Json
}

model EntityProjection {
  id                String   @id
  projectionVersion Int
  lastEventId       String?
  generatedAt       DateTime @default(now())

  data Json
}

model MemoryCardProjection {
  id                String   @id
  projectionVersion Int
  lastEventId       String?
  generatedAt       DateTime @default(now())

  data Json
}

model HealthProjection {
  id                String   @id
  projectionVersion Int
  lastEventId       String?
  generatedAt       DateTime @default(now())

  data Json
}

// ------------------------------------------------------
// 7. Platform Metrics
// ------------------------------------------------------

model PlatformMetric {
  id        String   @id
  name      String // e.g. 'capture_latency', 'queue_depth'
  value     Float
  tags      Json     @default("{}")
  timestamp DateTime @default(now())

  @@index([name, timestamp])
}

// ------------------------------------------------------
// 8. Daily Briefing (Ranked Front Page)
// ------------------------------------------------------

model DailyBriefingSnapshot {
  id          String   @id
  contextId   String
  date        DateTime
  generatedAt DateTime @default(now())
  totalItems  Int
  metadata    Json     @default("{}")

  items DailyBriefingItem[]

  @@index([contextId, date])
  @@index([date])
}

model DailyBriefingItem {
  id         String                @id
  snapshotId String
  snapshot   DailyBriefingSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  entityId   String?
  type       String
  title      String
  subtitle   String?
  rank       Float
  category   String
  payload    Json                  @default("{}")

  @@index([snapshotId, rank])
  @@index([entityId])
}

// ------------------------------------------------------
// 9. Identity Physics (Collapse & Conflict)
// ------------------------------------------------------

model ConflictPressureItem {
  id            String   @id @default(uuid())
  entityAId     String
  entityBId     String
  pressureScore Float
  reason        String
  status        String   // OPEN / RESOLVED / IGNORED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([entityAId, entityBId])
  @@index([status])
}
